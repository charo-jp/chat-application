# Template for environment variables. Committed to version control.
# Copy this to .env.development (local dev) or .env.production and fill
# in real values. Do NOT put real secrets in this file.
#
# NODE_ENV is intentionally NOT listed here: it selects which .env file
# is loaded, so it must be set by the npm script or deploy platform,
# not from inside an env file.

# PostgreSQL connection string.
# Example: postgresql://chat_app_dev:password@localhost:5432/howdi
DATABASE_URL=

# Secret used to sign JWTs (long, random string).
JWT_REFRESH_TOKEN_SECRET=
JWT_ACCESS_TOKEN_SECRET=
